{"lexicon" 1
 "id" "com.etzhayyim.shomei.verificationChallenge"
 "description" "Ephemeral, single-use challenge nonce a member requests BEFORE signing a proof-of-control for an external identity (CAIP-122 / SIWE / Bitcoin-Signed-Message / OAuth-state shaped). Per ADR-2606072100 (shomei). The member binds this nonce into the signed payload so a captured signature cannot be replayed against a different DID or factor. The challenge is bound to `subjectDid` + `factorKind` and expires at `expiresAt`. The server only ISSUES and records consumption (G7 no-server-key: the server never signs anything); the member's wallet / authenticator / IdP produces the signature off the nonce. Verifiers reject a claim whose nonce is unknown, already consumed, expired, or bound to a different subject/factor."
 "defs" {"main" {"type" "record"
 "key" "tid"
 "record" {"type" "object"
 "additionalProperties" false
 "required" ["subjectDid"
 "factorKind"
 "nonce"
 "issuedAt"
 "expiresAt"]
 "properties" {"subjectDid" {"type" "string"
 "format" "did"
 "description" "DID of the member who requested the challenge and who will sign it. The signed proof MUST embed this exact DID; a signature bound to a different DID is rejected (anti-relay)."}
 "factorKind" {"type" "string"
 "enum" ["webauthn"
 "wallet-evm"
 "wallet-btc"
 "sns-github"
 "sns-x"
 "sns-google"
 "sns-apple"
 "gov-mynumber"
 "gov-passport"
 "gov-license"
 "etz-base-membership"
 "etz-adherent-sbt"
 "etz-at-oath"]
 "description" "Which external identity factor this challenge will bind. The eventual identityClaim MUST carry the same factorKind."}
 "nonce" {"type" "string"
 "description" "Cryptographically-random nonce (\u2265 128 bits, base64url or hex). Single-use: a verifier marks it consumed on first successful claim and rejects any reuse."
 "minLength" 16
 "maxLength" 256}
 "issuedAt" {"type" "integer"
 "description" "Unix timestamp (seconds) the challenge was issued."}
 "expiresAt" {"type" "integer"
 "description" "Unix timestamp (seconds) after which the challenge is invalid. Recommended TTL \u2264 600s. Verifiers reject claims signed against an expired nonce."
 "minimum" 0}}}}}}
